{
  "name": "veggie-watch-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "node --env-file .env --import=tsx --watch src/app.ts",
    "dev:up": "docker compose --env-file .env up -d",
    "dev:down": "docker compose --env-file .env down",
    "start": "node -r tsconfig-paths/register ./dist/app.js",
    "staging:up": "docker compose --env-file .env.staging -f docker-compose.staging.yml up -d --build",
    "staging:down": "docker compose --env-file .env.staging -f docker-compose.staging.yml down",
    "production:up": "docker compose --env-file .env.production -f docker-compose.production.yml up -d --build",
    "production:down": "docker compose --env-file .env.production -f docker-compose.production.yml down",
    "db:generate": "node --env-file .env ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate:prod": "node ./dist/db/migrate.js",
    "clean": "rimraf dist",
    "build": "pnpm run clean && tsc -b tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.7.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "dependencies": {
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/pino": "^7.0.5",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
